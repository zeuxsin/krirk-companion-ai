# ============================================
# KRIRK - Companion AI Desktop
# Copie este arquivo para .env e configure
# ============================================

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Servidor backend
BACKEND_HOST=localhost
BACKEND_PORT=8000

# TTS
TTS_VOICE=pt-BR-FranciscaNeural
TTS_ENABLED=true

# STT (requer Python <=3.12 para faster-whisper)
STT_ENABLED=false
STT_MODEL=base
STT_LANGUAGE=pt

# Telegram (a Krirk no celular) — crie o bot no @BotFather e cole o token
# TELEGRAM_BOT_TOKEN=

# Logs
LOG_LEVEL=INFO

# ============================================
# Provedores de LLM (free tiers em cascata de fallback)
# Cada um aceita uma 2ª chave <VAR>_2 → dobra o limite (assume quando a 1ª
# estoura). Deixe em branco os que não usar — são pulados automaticamente.
# ============================================
NVIDIA_API_KEY=
NVIDIA_API_KEY_2=

GOOGLE_API_KEY=
GOOGLE_API_KEY_2=

CEREBRAS_API_KEY=
CEREBRAS_API_KEY_2=

GROQ_API_KEY=
GROQ_API_KEY_2=

COHERE_API_KEY=
COHERE_API_KEY_2=

MISTRAL_API_KEY=
MISTRAL_API_KEY_2=

OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
