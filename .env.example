# ============================================
# KRIRK - Companion AI Desktop
# Copie este arquivo para .env e configure
# ============================================

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Servidor backend
BACKEND_HOST=localhost
BACKEND_PORT=8000

# TTS
TTS_VOICE=pt-BR-FranciscaNeural
TTS_ENABLED=true

# STT (requer Python <=3.12 para faster-whisper)
STT_ENABLED=false
STT_MODEL=base
STT_LANGUAGE=pt

# Logs
LOG_LEVEL=INFO

# (Futuro - Cloud fallback)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
