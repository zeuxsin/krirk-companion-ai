{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KRIRK",
  "version": "0.1.0",
  "identifier": "com.krirk.companion",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KRIRK",
        "url": "/",
        "width": 560,
        "height": 420,
        "minWidth": 420,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "KRIRK — Configurações",
        "url": "/?window=settings",
        "width": 420,
        "height": 340,
        "minWidth": 380,
        "minHeight": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
